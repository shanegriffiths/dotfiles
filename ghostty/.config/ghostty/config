# ============================================
# Ghostty Terminal - Configuration
# ============================================
# Reload: Cmd+Shift+, (macOS)
# View options: ghostty +show-config --default --docs

# --- Typography ---
font-family = Liga SFMono Nerd Font
font-size = 13
font-thicken = false
adjust-cell-height = 2

# --- Theme and Colors ---
# Auto-switches with macOS appearance: GitHub Light (high contrast) / custom Mocha
theme = light:GitHub Light HC Red,dark:Catppuccin Mocha Custom
# Floor on text-vs-background contrast so no color renders near-invisible (both modes)
minimum-contrast = 1.1

# --- Window and Appearance ---
background-opacity = 1
background-blur-radius = 20
macos-titlebar-style = transparent
macos-option-as-alt = true
window-padding-x = 16
window-padding-y = 16,0
window-padding-balance = false
window-save-state = always
window-theme = auto
confirm-close-surface = false
# Don't dim/mute the inactive split pane
unfocused-split-opacity = 1

# --- Cursor ---
cursor-style = block
cursor-style-blink = true
cursor-opacity = 0.8
# cursor-color inherited from theme
shell-integration-features = no-cursor

# --- Mouse ---
mouse-hide-while-typing = true
copy-on-select = true

# --- Quick Terminal (Quake-style dropdown) ---
# Toggle: Ctrl+` (global hotkey, works from any app)
quick-terminal-position = top
quick-terminal-size = 40%
quick-terminal-screen = mouse
quick-terminal-autohide = false
quick-terminal-animation-duration = 0.12

# --- Security & Clipboard ---
clipboard-read = allow
clipboard-write = allow
clipboard-paste-protection = true
clipboard-paste-bracketed-safe = true

# --- Shell Integration ---
shell-integration = zsh

# --- Keybindings ---
# Font size
keybind = cmd+plus=increase_font_size:1
keybind = cmd+minus=decrease_font_size:1
keybind = cmd+zero=reset_font_size

# Quick terminal global hotkey
keybind = global:ctrl+grave_accent=toggle_quick_terminal

# Reload config
keybind = cmd+shift+comma=reload_config

# --- Performance ---
scrollback-limit = 25000000
