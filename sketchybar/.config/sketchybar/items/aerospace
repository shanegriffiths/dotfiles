#!/usr/bin/env bash

# Add aerospace event
sketchybar --add event aerospace_workspace_change

# Static workspace list — mirrors workspace-to-monitor-force-assignment
# in aerospace.toml. Items always render regardless of monitor presence.
MAIN_WORKSPACES=(1 2 3 4 5 6 7)
SECONDARY_WORKSPACES=(8 9)

items_cmd=()

add_workspace() {
    local id="$1"
    items_cmd+=(
        --add item "space.$id" left
        --subscribe "space.$id" aerospace_workspace_change
        --set "space.$id"
        background.color=0xffd13539
        background.corner_radius=10
        background.height=28
        background.drawing=off
        background.border_color=0xff666666
        background.border_width=1
        label="$id"
        label.font="SF Pro:Medium:13.0"
        label.padding_left=0
        label.padding_right=12
        icon.drawing=off
        icon.padding_left=12
        icon.padding_right=12
        click_script="aerospace workspace $id"
        script="$CONFIG_DIR/plugins/aerospace.sh $id"
    )
}

add_workspace_spacer() {
    local id="$1"
    items_cmd+=(
        --add item "workspace_spacer.$id" left
        --set "workspace_spacer.$id"
        width=12
        background.drawing=off
    )
}

# Main monitor workspaces
for i in "${!MAIN_WORKSPACES[@]}"; do
    add_workspace "${MAIN_WORKSPACES[$i]}"
    if [ $i -lt $((${#MAIN_WORKSPACES[@]} - 1)) ]; then
        add_workspace_spacer "${MAIN_WORKSPACES[$i]}"
    fi
done

# Separator between monitors
items_cmd+=(
    --add item "monitor_spacer.main" left
    --set "monitor_spacer.main"
    width=40
    background.drawing=off
)

# Secondary monitor workspaces
for i in "${!SECONDARY_WORKSPACES[@]}"; do
    add_workspace "${SECONDARY_WORKSPACES[$i]}"
    if [ $i -lt $((${#SECONDARY_WORKSPACES[@]} - 1)) ]; then
        add_workspace_spacer "${SECONDARY_WORKSPACES[$i]}"
    fi
done

# Trailing spacer separating workspaces from front_app
items_cmd+=(
    --add item "workspaces_end_spacer" left
    --set "workspaces_end_spacer"
    width=24
    background.drawing=off
)

# Execute all workspace additions in a single batched command
sketchybar "${items_cmd[@]}"
